  },
  "dependencies": {
    "@oh-my-trace/core": "0.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agent",
    "trace",
    "mcp",
    "codex",
    "claude",
    "gemini",
    "copilot"
