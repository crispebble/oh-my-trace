{
  "name": "oh-my-trace-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Workspace for oh-my-trace CLI, MCP, and shared core packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "node --test packages/cli/test/*.test.js",
    "pack:core:dry-run": "npm pack --workspace @oh-my-trace/core --dry-run",
    "pack:core": "npm pack --workspace @oh-my-trace/core",
    "pack:cli:dry-run": "npm pack --workspace @oh-my-trace/cli --dry-run",
    "pack:cli": "npm pack --workspace @oh-my-trace/cli",
    "pack:mcp:dry-run": "npm pack --workspace @oh-my-trace/mcp --dry-run",
    "pack:mcp": "npm pack --workspace @oh-my-trace/mcp",
    "publish:core": "npm publish --workspace @oh-my-trace/core --access public",
    "publish:cli": "npm publish --workspace @oh-my-trace/cli --access public",
    "publish:mcp": "npm publish --workspace @oh-my-trace/mcp --access public"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
