{
  "name": "oh-my-trace-workspace",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "oh-my-trace-workspace",
      "version": "0.1.0",
      "license": "MIT",
      "workspaces": [
        "packages/*"
      ],
      "engines": {
        "node": ">=20"
      }
    },
    "node_modules/@oh-my-trace/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/oh-my-trace": {
      "resolved": "packages/cli",
      "link": true
    },
    "node_modules/oh-my-trace-mcp": {
      "resolved": "packages/mcp",
      "link": true
    },
    "packages/cli": {
      "name": "oh-my-trace",
      "version": "0.1.0",
      "hasInstallScript": true,
      "license": "MIT",
      "dependencies": {
        "@oh-my-trace/core": "0.1.0"
      },
      "bin": {
        "omt": "bin/omt.js"
      },
      "engines": {
        "node": ">=20"
      }
    },
    "packages/core": {
      "name": "@oh-my-trace/core",
      "version": "0.1.0",
      "license": "MIT",
      "engines": {
        "node": ">=20"
      }
    },
    "packages/mcp": {
      "name": "oh-my-trace-mcp",
      "version": "0.1.0",
      "hasInstallScript": true,
      "license": "MIT",
      "dependencies": {
        "@oh-my-trace/core": "0.1.0"
      },
      "bin": {
        "oh-my-trace-mcp": "bin/oh-my-trace-mcp.js"
      },
      "engines": {
        "node": ">=20"
      }
    }
  }
}
